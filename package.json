{
  "name": "camera-keyword-tool",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "vite",
    "dev:api": "vercel dev --listen 3000",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.jsx,.mjs,.cjs",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.js --project=chromium",
    "validate:presets": "node scripts/validate-angle-presets.mjs",
    "check": "npm run validate:presets && npm run lint && npm run typecheck && npm run test:unit && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.128.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8",
    "vite": "^4.4.0"
  }
}
