# Supabase project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase public anon key
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: force OAuth return URL (recommended for production)
# Example: https://icecam.icedong.com
VITE_AUTH_REDIRECT_URL=

# Local dev API target for Vite proxy (/api -> this server)
VITE_LOCAL_API_TARGET=http://127.0.0.1:3000

# Gemini API key (server-side, used by /api/translate)
GEMINI_API_KEY=your-gemini-api-key
# Legacy fallback (optional)
# GOOGLE_TRANSLATE_KEY=

# Analytics (client + server)
# Set to false to disable all frontend event logging
VITE_ANALYTICS_ENABLED=true
# Optional debug logging in browser console
VITE_ANALYTICS_DEBUG=false
# Optional webhook sink for /api/analytics (leave empty to log on server)
ANALYTICS_WEBHOOK_URL=
# Optional Bearer token for analytics webhook forwarding
ANALYTICS_WEBHOOK_TOKEN=

# Optional: comma-separated allowed web origins for API endpoints
# Example: https://camera-keyword.example.com,https://preview.example.com
ALLOWED_ORIGINS=

# Optional: distributed rate-limit backend (recommended for Vercel multi-instance)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Rollback threshold monitor defaults
ROLLBACK_ERROR_RATE_THRESHOLD=0.02
ROLLBACK_P95_MS_THRESHOLD=3000
ROLLBACK_EVAL_WINDOW_SEC=600
ROLLBACK_MIN_SAMPLE_SIZE=20
ROLLBACK_ALERT_COOLDOWN_SEC=300

# Optional rollback/SLO alert sink
ROLLBACK_ALERT_WEBHOOK_URL=
ROLLBACK_ALERT_WEBHOOK_TOKEN=

# Usage / token-cost guard defaults
USAGE_WINDOW_SEC=600
USAGE_LOG_COOLDOWN_SEC=30
USAGE_FAILURE_ALERT_THRESHOLD=0.25
USAGE_FAILURE_ALERT_MIN_REQUESTS=20
USAGE_TOKEN_BUDGET_PER_MINUTE=120000
USAGE_MAX_MODEL_CALLS_DEFAULT=6
USAGE_MAX_MODEL_CALLS_TRANSLATE=4
USAGE_MAX_MODEL_CALLS_REFINE=6

# Optional: enable design-only Interactive UI refresh (legacy is default)
# Set to 1 to enable, leave empty for instant rollback.
VITE_INTERACTIVE_DESIGN_REFRESH=
