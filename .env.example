# Supabase project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase public anon key
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: force OAuth return URL (recommended for production)
# Example: https://icecam.icedong.com
VITE_AUTH_REDIRECT_URL=

# Google Cloud Translation API key (server-side, used by /api/translate)
GOOGLE_TRANSLATE_KEY=your-google-translate-api-key
