# Supabase project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase public anon key
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: force OAuth return URL (recommended for production)
# Example: https://icecam.icedong.com
VITE_AUTH_REDIRECT_URL=

# Gemini API key (server-side, used by /api/translate)
GEMINI_API_KEY=your-gemini-api-key
# Legacy fallback (optional)
# GOOGLE_TRANSLATE_KEY=

# Analytics (client + server)
# Set to false to disable all frontend event logging
VITE_ANALYTICS_ENABLED=true
# Optional debug logging in browser console
VITE_ANALYTICS_DEBUG=false
# Optional webhook sink for /api/analytics (leave empty to log on server)
ANALYTICS_WEBHOOK_URL=
# Optional Bearer token for analytics webhook forwarding
ANALYTICS_WEBHOOK_TOKEN=
