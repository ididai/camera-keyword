{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node", "vite/client", "vitest/globals"]
  },
  "include": ["src/**/*.js", "src/**/*.jsx", "api/**/*.js", "vite.config.js", "tests/**/*.js"],
  "exclude": ["dist", "node_modules"]
}
